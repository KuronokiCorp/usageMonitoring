{
  "name": "itermon",
  "version": "1.1.1",
  "description": "Monitor and control iTerm2 sessions from a CLI or local web admin, with a cron scheduler for recurring sends.",
  "scripts": {
    "start": "bash start.sh",
    "start:open": "bash start.sh --open",
    "web": "bash start.sh",
    "list": "python3 iterm_ctl.py list",
    "watch": "python3 iterm_ctl.py watch",
    "send": "python3 iterm_ctl.py send",
    "read": "python3 iterm_ctl.py read",
    "publish:npm": "bash -c 'set -a; . ./.env 2>/dev/null; set +a; npm publish \"--//registry.npmjs.org/:_authToken=$NPM_TOKEN\"'"
  },
  "bin": {
    "iterm-ctl": "iterm_ctl.py",
    "iterm-admin": "start.sh"
  },
  "files": [
    "iterm_ctl.py",
    "iterm_web.py",
    "start.sh",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "os": [
    "darwin"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KuronokiCorp/usageMonitoring.git"
  },
  "keywords": [
    "iterm2",
    "iterm",
    "terminal",
    "automation",
    "claude-code",
    "monitoring",
    "cron"
  ],
  "license": "MIT"
}
